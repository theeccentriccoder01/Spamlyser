# =============================================================================
# Spamlyser Pro - Streamlit Secrets Configuration
# =============================================================================
# This file is for Streamlit Cloud / deployment secrets
# Copy to .streamlit/secrets.toml and fill in your values
# Local: Never commit to version control (add to .gitignore)
# Cloud: Use the Streamlit dashboard to set secrets
# =============================================================================


# =============================================================================
# API CREDENTIALS
# =============================================================================

# HuggingFace API Token
# Get it from: https://huggingface.co/settings/tokens
hf_token = ""

# GitHub API Token
# Get it from: https://github.com/settings/tokens
github_token = ""

# Database connection strings (if using external DB)
# db_host = "localhost"
# db_port = 5432
# db_user = "spamlyser"
# db_password = ""
# db_name = "spamlyser_feedback"


# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Override default model name
# verification_model_name = "distilbert-base-uncased"

# Model cache directory (for cloud deployments)
# model_cache_dir = "/tmp/huggingface_cache"


# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
# features = {
#     word_analysis = true,
#     threat_analysis = true,
#     feedback_system = true,
#     model_explainability = true,
#     batch_processing = true,
#     pdf_export = true,
#     dark_mode = true
# }


# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Sentry DSN for error tracking (optional)
# sentry_dsn = ""

# Enable analytics
# analytics_enabled = true

# Log level
# log_level = "info"


# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================

# Streamlit server configuration
# [server]
# port = 8501
# headless = true
# runOnSave = true
# logger.level = "info"


# =============================================================================
# NOTES
# =============================================================================
#
# Local Development:
#   1. Copy this file to .streamlit/secrets.toml
#   2. Fill in your values
#   3. secrets.toml is in .gitignore - never commit it!
#   4. Access secrets in code: st.secrets["key_name"]
#
# Streamlit Cloud:
#   1. Go to: https://share.streamlit.io/
#   2. Click on your app
#   3. Settings → Secrets → Copy-paste your values
#   4. Changes take effect on next deploy
#
# Format:
#   - Strings: key = "value"
#   - Numbers: key = 123
#   - Booleans: key = true/false
#   - Lists: key = [1, 2, 3]
#   - TOML sections: [section] key = "value"
#
