# =============================================================================
# Spamlyser Pro - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control - it's in .gitignore for a reason!
# =============================================================================


# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Name of the verification model to use
# Default: distilbert-base-uncased
# Options: distilbert-base-uncased, bert-base-uncased, roberta-base, albert-base-v2
VERIFICATION_MODEL_NAME=distilbert-base-uncased

# Directory where HuggingFace models will be cached
# Default: ~/.cache/huggingface
# Example: /home/user/.cache/huggingface or C:\Users\user\.cache\huggingface
MODEL_CACHE_DIR=

# Whether to use model quantization (int8) for faster inference
# Default: true
USE_QUANTIZATION=true

# Whether to use dynamic quantization when CUDA is unavailable
# Default: true
USE_DYNAMIC_QUANTIZATION=true

# Whether to cache loaded models in memory
# Default: true
CACHE_MODELS=true


# =============================================================================
# FEEDBACK & DATA CONFIGURATION
# =============================================================================

# Path to feedback JSON file (legacy, for migration)
# Default: feedback_data.json
FEEDBACK_JSON_PATH=feedback_data.json

# Path to feedback SQLite database
# Default: feedback_data.db
FEEDBACK_DB_PATH=feedback_data.db


# =============================================================================
# DATA DIRECTORIES
# =============================================================================

# Directory for CSV data files
# Default: csv
CSV_DIR=csv

# Directory for assets
# Default: assets
ASSETS_DIR=assets

# Directory for images
# Default: imgs
IMGS_DIR=imgs


# =============================================================================
# EXTERNAL APIs & CREDENTIALS
# =============================================================================

# HuggingFace API Token (optional)
# Get it from: https://huggingface.co/settings/tokens
# Required for: Downloading private models, pushing to Hub
HF_TOKEN=

# GitHub API Token (optional)
# Get it from: https://github.com/settings/tokens
# Required for: Exporting feedback as GitHub issues
GITHUB_TOKEN=


# =============================================================================
# STREAMLIT CONFIGURATION
# =============================================================================

# Streamlit theme preference
# Default: dark
# Options: light, dark
STREAMLIT_THEME=dark

# Streamlit server port
# Default: 8501
STREAMLIT_PORT=8501

# Streamlit logger level
# Default: info
# Options: debug, info, warning, error
STREAMLIT_LOGGER_LEVEL=info


# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application name
# Default: Spamlyser Pro
APP_NAME=Spamlyser Pro

# Application version
# Default: 1.0.0
APP_VERSION=1.0.0

# Enable debug mode (more verbose logging, additional debugging info)
# Default: false
DEBUG_MODE=false

# Application log level
# Default: info
# Options: debug, info, warning, error, critical
LOG_LEVEL=info


# =============================================================================
# BATCH PROCESSING
# =============================================================================

# Batch size for processing multiple messages
# Default: 32
# Range: 1-128 (depends on available memory)
BATCH_SIZE=32

# Maximum number of worker threads for parallel processing
# Default: 4
# Range: 1-16 (depends on CPU cores)
MAX_WORKERS=4


# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Set to 'true' to enable, 'false' to disable
# Default: all features are enabled

# Enable word analysis feature
FEATURE_WORD_ANALYSIS=true

# Enable threat analysis feature
FEATURE_THREAT_ANALYSIS=true

# Enable feedback system
FEATURE_FEEDBACK_SYSTEM=true

# Enable model explainability
FEATURE_MODEL_EXPLAINABILITY=true

# Enable batch processing
FEATURE_BATCH_PROCESSING=true

# Enable PDF export
FEATURE_PDF_EXPORT=true

# Enable dark mode toggle
FEATURE_DARK_MODE=true


# =============================================================================
# NOTES
# =============================================================================
#
# 1. All paths can be absolute or relative to the project root
# 2. Leave blank to use defaults
# 3. Boolean values: true, 1, yes (case-insensitive) = True; everything else = False
# 4. Never commit sensitive data (API keys, tokens) to version control!
# 5. Use python-dotenv to load this file:
#    from dotenv import load_dotenv
#    load_dotenv()
#
